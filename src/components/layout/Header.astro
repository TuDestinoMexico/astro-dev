---
import MenuBar from "../ui/MenuBar.astro";
import SubMenu from "../ui/SubMenu.astro";
---
<div class="space-y-5">
    <div class="container mx-auto xl:grid grid-cols-2 items-center pb-5">
        <div class="h-full flex items-center xl:justify-start justify-center mt-5 xl:mt-0">
            <a href="/">
                <img
                        class="w-70"
                        src="https://storage.googleapis.com/tudestinomx_bucket/assets/test/tdmx-logo-purpel.png"
                        alt="Tu Destino Mexico"
                >
            </a>
        </div>
        <div class="xl:flex h-auto flex-row font-bold rounded-bl-xl overflow-hidden text-sm justify-end hidden">
            <MenuBar title="Solo ventas" subtitle="(998) 980 6611" url="tel:529989806611" color="bg-green-400" icon="fa7-solid:phone" />
            <MenuBar title="WhatsApp" subtitle="(998) 714 1365" url="https://wa.me/529987141365" color="bg-green-600" icon="simple-icons:whatsapp" />
            <MenuBar title="Pagar en linea" subtitle="lo hacemos facil" url="/pagos" color="bg-lime-500" icon="fa7-solid:credit-card" />
            <MenuBar title="Quienes Somos" subtitle="La familia Xolo" url="/about" color="bg-orange-500" icon="fa7-solid:people-group" />
        </div>
    </div>

    <div id="sticky-header-container" class="relative">

        <nav id="main-nav" class="relative w-full z-[100] transition-all duration-300">
            <div id="nav-bg" class="absolute inset-0 bg-transparent transition-all duration-300"></div>

            <div class="container mx-auto px-5 relative">
                <div
                        id="nav-content"
                        class="flex flex-row items-center justify-center py-4 transition-all duration-300 gap-5"
                >
                    <a
                            href="/"
                            id="logo-scroll"
                            class="w-0 opacity-0 overflow-hidden transition-all duration-300 ease-in-out flex-shrink-0 pointer-events-none"
                    >
                        <img
                                class="w-40 md:w-48"
                                src="https://storage.googleapis.com/tudestinomx_bucket/assets/test/tdmx-logo-purpel.png"
                                alt="Tu Destino Mexico"
                        />
                    </a>

                    <div class="flex flex-row gap-6 text-md xl:text-lg font-bold overflow-x-auto no-scrollbar py-2 flex-shrink-0">
                        <SubMenu title="Hoteles" icon="balcony" url="/hoteles" />
                        <SubMenu title="Tours" icon="tour" url="/tours" />
                        <SubMenu title="Destinos" icon="public" url="/destinos" />
                        <SubMenu title="Convenios" icon="handshake" url="/convenios" />
                        <SubMenu title="XoloRuta" icon="place" url="/xolo-ruta" />
                    </div>
                </div>
            </div>
        </nav>

        <div id="nav-spacer" class="h-0 transition-all duration-300"></div>
    </div>
</div>

<style>
    .no-scrollbar::-webkit-scrollbar { display: none; }
    .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

    /* Mejoras de rendimiento en animación */
    #nav-content, #nav-bg, #logo-scroll, #nav-spacer {
        will-change: transform, opacity, width, padding, height;
    }
</style>

<script>
    // IDs sincronizados
    const nav = document.getElementById('main-nav');
    const navBg = document.getElementById('nav-bg');
    const navContent = document.getElementById('nav-content');
    const logoScroll = document.getElementById('logo-scroll');
    const spacer = document.getElementById('nav-spacer');

    window.addEventListener('scroll', () => {
        const isScrolled = window.scrollY > 150; // Punto de activación ajustable

        if (isScrolled) {
            // --- MODO FOLLOW: Pegajoso ---

            // 1. Activar 'fixed' y sombra
            nav?.classList.add('fixed', 'top-0', 'left-0', 'shadow-lg');
            nav?.classList.remove('relative');

            // 2. SOLUCIÓN FONDO: Fondo blanco sólido e imperecedero
            navBg?.classList.replace('bg-transparent', 'bg-white');

            // 3. SOLUCIÓN SALTO: El espaciador 'crece' para ocupar el hueco
            // Haremos que la transición del espaciador coincida con la del menú (aprox 80px)
            spacer?.classList.add('h-[88px]');

            // --- Resto de animaciones visuales ---
            navContent?.classList.replace('justify-center', 'justify-between');

            logoScroll?.classList.remove('w-0', 'opacity-0', 'pointer-events-none');
            logoScroll?.classList.add('w-48', 'opacity-100');

            // Hacer el menú un poco más delgado al bajar
            navContent?.classList.replace('py-4', 'py-2');

        } else {
            // --- MODO NORMAL: Arriba ---

            // 1. Quitar 'fixed' y sombra
            nav?.classList.remove('fixed', 'top-0', 'left-0', 'shadow-lg');
            nav?.classList.add('relative');

            // 2. SOLUCIÓN FONDO: Volver a transparente
            navBg?.classList.replace('bg-white', 'bg-transparent');

            // 3. SOLUCIÓN SALTO: Ocultar el espaciador
            spacer?.classList.remove('h-[88px]');

            // --- Restaurar animaciones visuales ---
            navContent?.classList.replace('justify-between', 'justify-center');

            logoScroll?.classList.add('w-0', 'opacity-0', 'pointer-events-none');
            logoScroll?.classList.remove('w-48', 'opacity-100');

            // Restaurar grosor normal
            navContent?.classList.replace('py-2', 'py-4');
        }
    });
</script>