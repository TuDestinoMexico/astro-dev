---
interface Props {
    title: string;
    icon: string;
    url: string;
    // Nueva prop: Por defecto es false (se muestra en todos lados)
    mobileOnly?: boolean;
}

const { title, icon, url, mobileOnly = false } = Astro.props;

// Obtenemos la ruta actual del navegador
const pathname = Astro.url.pathname;

// Comparamos si la ruta actual coincide con la URL del componente
const isActive = pathname === url || pathname.replace(/\/$/, "") === url.replace(/\/$/, "");
---

<a
        href={url}
        class:list={[
            // Clases base
        "flex-col items-center gap-1 transition-colors",

            // LÓGICA RESPONSIVA:
        // Si mobileOnly es true, se oculta en escritorio ('md:hidden') y se ve en móvil ('flex').
        // Si es false, se ve en todos lados ('flex').
        mobileOnly ? "flex md:hidden" : "flex",

            {
                "text-purple-800 font-bold border-b-2 border-purple-800": isActive, // Activo
            "text-slate-600 hover:text-purple-800": !isActive // Inactivo
        }
        ]}
>
    <span class="material-icons-outlined icons text-3xl">{icon}</span>
    <span class="text-xs md:text-sm text-center">{title}</span>
</a>