---
interface Props {
    title: string;
    icon: string;
    url: string; // Lo hacemos obligatorio para poder comparar
}

const { title, icon, url } = Astro.props;

// Obtenemos la ruta actual del navegador
const pathname = Astro.url.pathname;

// Comparamos si la ruta actual coincide con la URL del componente
// El .replace/\/$/, "") sirve para quitar la barra diagonal final (trailing slash)
// y que la comparación no falle entre "/hoteles" y "/hoteles/"
const isActive = pathname === url || pathname.replace(/\/$/, "") === url.replace(/\/$/, "");
---

<a
        href={url}
        class:list={[
            "flex flex-col items-center gap-1 transition-colors",
            {
                "text-purple-800 font-bold border-b-2 border-purple-800": isActive, // Clases cuando está activo
            "text-slate-600 hover:text-purple-800": !isActive // Clases cuando no está activo
        }
        ]}
>
    <span class="material-icons-outlined icons text-3xl">{icon}</span>
    <span class="text-xs md:text-sm">{title}</span>
</a>