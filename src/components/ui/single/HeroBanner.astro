---
interface Props {
    title: string;
    imageSrc?: string;
    videoSrc?: string;
    altText?: string;
}

const { title, imageSrc, videoSrc, altText = "Encabezado de página" } = Astro.props;
---

<header class="relative mx-4 my-5 flex min-h-64 md:min-h-80 items-center justify-center overflow-hidden rounded-lg xl:mx-0">

    <!-- Capa oscura (Overlay) y Título -->
    <!-- 'inset-0' es el equivalente a 'top-0 right-0 bottom-0 left-0 w-full h-full' -->
    <div class="absolute inset-0 z-20 flex flex-col items-center justify-center gap-3 bg-black/50 text-white">
        <h1 class="px-4 text-center text-4xl font-bold md:text-5xl">
            {title}
        </h1>
    </div>

    <!-- Renderizado Condicional: Video vs Imagen -->
    {videoSrc ? (
            <video
                    class="absolute inset-0 z-10 h-full w-full object-cover"
                    src={videoSrc}
                    poster={imageSrc}
                    autoplay
                    loop
                    muted
                    playsinline
            ></video>
    ) : (
        imageSrc && (
                <img
                        class="absolute inset-0 z-10 h-full w-full object-cover"
                        src={imageSrc}
                        alt={altText}
                        fetchpriority="high"
                />
        )
    )}
</header>