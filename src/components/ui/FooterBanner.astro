---
interface Props {
    bgImage?: string;
}

const {
    bgImage = "https://storage.googleapis.com/tudestinomx_bucket/assets/test/fondo_lego_xolito.jpeg"
} = Astro.props;
---

{/* CONTENEDOR PADRE: Sin overflow-hidden para permitir que Xolo sobresalga por arriba */}
<div
        id="xolo-banner"
        class="relative mt-20 md:mt-28 h-72 md:h-112.5 w-[92%] container mx-auto"
>
    {/* 1. CAPA DE FONDO (Con bordes redondeados y recorte aislado) */}
    <div class="absolute inset-0 rounded-[2.5rem] overflow-hidden z-0">
        <img
                src={bgImage}
                alt="Fondo Xolo Banner"
                class="w-full h-full object-cover"
        />
        {/* Sombrado para legibilidad del texto */}
        <div class="absolute inset-0 bg-gradient-to-t from-slate-950/90 via-slate-950/50 to-slate-950/20"></div>
    </div>

    {/* 2. CAPA DE LA MASCOTA XOLO (Sobresale por arriba con h-[125%] / h-[135%]) */}
    <div class="absolute inset-0 flex w-full h-full pointer-events-none select-none z-10 items-end justify-center">
        <img
                src="https://storage.googleapis.com/tudestinomx_bucket/assets/test/xolo_lego_transparente.png"
                alt="Xolo Tu Destino Mexico"
                class="absolute bottom-0 w-auto h-[125%] md:h-[135%] object-contain object-bottom drop-shadow-[0_15px_15px_rgba(0,0,0,0.6)]"
        />
    </div>

    {/* 3. CAPA DEL TEXTO PRINCIPAL */}
    <div class="absolute z-20 w-full flex justify-center bottom-4 md:-bottom-6 left-0 right-0 px-4 pointer-events-none">
        <h2 class="text-white text-[8.4vw] md:text-7xl lg:text-[150px] font-black tracking-tighter leading-none select-none text-center uppercase whitespace-nowrap drop-shadow-[0_10px_10px_rgba(0,0,0,0.8)]">
            TuDestinoMéxico
        </h2>
    </div>

</div>

<script>
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const banner = document.getElementById('xolo-banner');

    if (banner) {
        gsap.to(banner, {
            width: "100%",
            maxWidth: "100%",
            borderRadius: "0px",

            scrollTrigger: {
                trigger: banner,
                start: "top 95%",
                end: "bottom bottom",
                scrub: 1,
                invalidateOnRefresh: true
            }
        });
    }
</script>