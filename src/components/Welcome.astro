---
import Banner from "./ui/Banner.astro";
import Grid from "./ui/Grid.astro";
import AppDownload from "./ui/home/AppDownload.astro";
import HeroSlider from "./ui/home/HeroSlider";
import YouTubeCTA from "./ui/home/YouTubeCTA.astro";
import Card from "./ui/single/Card.astro";
import Content from "./layout/Content.astro";
import WelcomeModal from "./modal/WelcomeModal";
import RecentlyViewed from "./ui/RecentlyViewed";
import PromoLocker from "./ui/PromoLocker";
import DigitalChannels from "./ui/home/DigitalChannels.astro";

const token = import.meta.env.VITE_API_TOKEN
const response = await fetch('https://api.tudestinomx.com/api/hotel', {
    headers: {
        'Accept': 'application/json',
        'Authorization': `Bearer ${token}`,
    }
});
const data = await response.json();
const hoteles = Array.isArray(data) ? data : (data.data || []);
---
<HeroSlider client:only="react" />

<Content>
    <WelcomeModal client:only="react" />

    <RecentlyViewed client:only="react" />

    <DigitalChannels />

    <YouTubeCTA />

    <Grid
                grid={5}
        >
            {hoteles.slice(0, 5).map(
                (
                    hotel: { name: string | undefined;
                        slug: string | undefined;
                        images: string | undefined;
                        destino: string | undefined;
                    }) => (
                        <Card
                                title={hotel.name}
                                slug={hotel.slug}
                                photo={hotel.images}
                                type="hotel"
                                destino={hotel.destino}
                        />
                ))}
    </Grid>

    <PromoLocker client:load>
        <Grid
                grid={3}
                title="Ofertas relampago"
        >
            <Banner
                    url="https://link.tudestinomx.com/DoradoRoyaleOffer"
                    src="https://storage.googleapis.com/tudestinomx_bucket/assets/promos/compress/Relampago-1-HS.png"
                    alt="El Dorado Royale Tu Destino Mexico"
                    className="rounded-2xl overflow-hidden"
            />
            <Banner
                    url="https://link.tudestinomx.com/DoradoSeasideOffer"
                    src="https://storage.googleapis.com/tudestinomx_bucket/assets/promos/compress/Relampago-2-HS.png"
                    alt="El Dorado Seaside"
                    className="rounded-2xl overflow-hidden"
            />
            <Banner
                    url="https://link.tudestinomx.com/HardRockRMOffer"
                    src="https://storage.googleapis.com/tudestinomx_bucket/assets/promos/compress/Relampago-3-HS.png"
                    alt="Hard Rock Riviera Maya"
                    className="rounded-2xl overflow-hidden"
            />
        </Grid>
    </PromoLocker>


        <!--<AppDownload />-->


</Content>


