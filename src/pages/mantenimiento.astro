---
import "../assets/styles/global.css"

// 1. Forzar el código de estado 503 (Servicio no disponible)
Astro.response.status = 503;

// 2. Indicar a los buscadores que regresen en 1 hora
Astro.response.headers.set('Retry-After', '3600');
Astro.response.headers.set('Cache-Control', 'no-store, no-cache, must-revalidate, max-age=0');
---
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Actualización | Tu Destino México</title>
    <meta name="robots" content="noindex, nofollow">
</head>
<body class="bg-white text-slate-900 font-sans flex items-center justify-center min-h-screen p-6">

<div class="max-w-md w-full text-center space-y-8">
    <div class="flex justify-center">
        <div class="p-6 bg-orange-500 rounded-3xl shadow-xl shadow-orange-500/20">
            <svg class="w-12 h-12 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
        </div>
    </div>

    <div class="space-y-4">
        <h1 class="text-4xl font-black uppercase tracking-tighter text-slate-900">
            Tu Destino <span class="text-orange-500">México</span>
        </h1>
        <h2 class="text-xl font-bold text-slate-800">Estamos preparando algo increíble</h2>
        <p class="text-slate-500 text-sm leading-relaxed">
            Estamos optimizando nuestros sistemas para ofrecerte la mejor experiencia en los Octavos de Final del Mundial 2026.
        </p>
    </div>

    <div class="flex items-center justify-center gap-3 py-4 border-y border-slate-100">
        <span class="w-2.5 h-2.5 bg-orange-500 rounded-full animate-pulse"></span>
        <span class="text-xs font-black text-slate-400 uppercase tracking-widest">Servidor en Mantenimiento</span>
    </div>

    <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">
        Volveremos en unos minutos. Gracias por tu paciencia.
    </p>
</div>

<script>
    // Si el sitio vuelve a estar activo, esta recarga forzará al middleware
    // a validar el estado y expulsar al usuario automáticamente al home.
    setInterval(() => {
        window.location.reload();
    }, 20000); // Verifica cada 20 segundos
</script>
</body>
</html>