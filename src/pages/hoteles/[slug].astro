---
export const prerender = false
import Layout from '../../layouts/Layout.astro';
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { Icon } from 'astro-icon/components';
import Gallery from '../../components/ui/hotel/Gallery.astro';
import BookingCalendar from '../../components/ui/BookingCalendar';
import HotelTabs from '../../components/ui/hotel/HotelTabs';

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

const token = import.meta.env.VITE_API_TOKEN;

const response = await fetch(`https://api.tudestinomx.com/api/hotel/slug/${slug}`, {
    headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json'
    }
});

if (!response.ok) {
    return Astro.redirect('/404');
}

const data = await response.json();
const hotel = data.data || data;

const amenities = hotel.amenities_list || [];
const coordinates = hotel.google_maps || [];

const rawImages = hotel.images || {};
const allImages = [
    ...(rawImages.principal || []),
    ...(rawImages.secundaria || []),
    ...(rawImages.adicional || [])
];
---

<Layout title={hotel.name || "Detalle de Hotel"}>
    <Header/>

    <main class="container mx-auto my-8 space-y-8 px-5 xl:px-0">

        <div class="space-y-4">
            <h1 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight">
                {hotel.name}
            </h1>

            <div class="flex flex-wrap items-center gap-y-3 gap-x-6 text-sm md:text-base">
                <div class="flex items-center gap-1.5 bg-yellow-50 px-3 py-1 rounded-full border border-yellow-200">
                    <Icon class="text-yellow-500" size="18" name="fa7-solid:star"/>
                    <span class="font-bold text-yellow-700">{hotel.reviews ?? 'N/A'}</span>
                </div>

                <div class="flex items-start gap-2 flex-1 min-w-0 text-slate-600 font-medium">
                    <Icon class="text-red-500 mt-0.5 flex-shrink-0" size="20" name="fa7-solid:location-dot"/>
                    <p class="truncate md:whitespace-normal">{hotel.address}</p>
                </div>
            </div>

            <Gallery images={allImages} hotelName={hotel.name} />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white border border-slate-100 shadow-sm rounded-2xl overflow-hidden">

                    <HotelTabs
                            client:load
                            description={hotel.description}
                            coordinates={coordinates}
                            address={hotel.address}
                            amenities={amenities}
                    />

                </div>
            </div>

            <div class="lg:col-span-1">
                <div class="bg-slate-50 border border-slate-200 p-6 rounded-2xl sticky top-24">
                    <div class="flex items-center gap-2 mb-4">
                        <Icon name="fa7-solid:calendar-check" size="24" class="text-emerald-600"/>
                        <h2 class="text-xl font-bold text-slate-800">Reserva tu estadía</h2>
                    </div>
                    <BookingCalendar client:visible hotelName={hotel.name} />
                </div>
            </div>

        </div>
    </main>

    <Footer/>
</Layout>