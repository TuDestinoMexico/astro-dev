---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";

const GROUPS = [
    {
        name: "Grupo A",
        highlight: true, // Destacamos el grupo del anfitrión México
        teams: [
            { name: "México", flag: "mx" },
            { name: "Sudáfrica", flag: "za" },
            { name: "República de Corea", flag: "kr" },
            { name: "República Checa", flag: "cz" }
        ]
    },
    {
        name: "Grupo B",
        teams: [
            { name: "Canadá", flag: "ca" },
            { name: "Bosnia y Herzegovina", flag: "ba" },
            { name: "Catar", flag: "qa" },
            { name: "Suiza", flag: "ch" }
        ]
    },
    {
        name: "Grupo C",
        teams: [
            { name: "Brasil", flag: "br" },
            { name: "Marruecos", flag: "ma" },
            { name: "Haití", flag: "ht" },
            { name: "Escocia", flag: "gb-sct" }
        ]
    },
    {
        name: "Grupo D",
        teams: [
            { name: "Estados Unidos", flag: "us" },
            { name: "Paraguay", flag: "py" },
            { name: "Australia", flag: "au" },
            { name: "Turquía", flag: "tr" }
        ]
    },
    {
        name: "Grupo E",
        teams: [
            { name: "Alemania", flag: "de" },
            { name: "Curazao", flag: "cw" },
            { name: "Costa de Marfil", flag: "ci" },
            { name: "Ecuador", flag: "ec" }
        ]
    },
    {
        name: "Grupo F",
        teams: [
            { name: "Países Bajos", flag: "nl" },
            { name: "Japón", flag: "jp" },
            { name: "Suecia", flag: "se" },
            { name: "Túnez", flag: "tn" }
        ]
    },
    {
        name: "Grupo G",
        teams: [
            { name: "Bélgica", flag: "be" },
            { name: "Egipto", flag: "eg" },
            { name: "RI de Irán", flag: "ir" },
            { name: "Nueva Zelanda", flag: "nz" }
        ]
    },
    {
        name: "Grupo H",
        teams: [
            { name: "España", flag: "es" },
            { name: "Cabo Verde", flag: "cv" },
            { name: "Arabia Saudí", flag: "sa" },
            { name: "Uruguay", flag: "uy" }
        ]
    },
    {
        name: "Grupo I",
        teams: [
            { name: "Francia", flag: "fr" },
            { name: "Senegal", flag: "sn" },
            { name: "Irak", flag: "iq" },
            { name: "Noruega", flag: "no" }
        ]
    },
    {
        name: "Grupo J",
        teams: [
            { name: "Argentina", flag: "ar" },
            { name: "Argelia", flag: "dz" },
            { name: "Austria", flag: "at" },
            { name: "Jordania", flag: "jo" }
        ]
    },
    {
        name: "Grupo K",
        teams: [
            { name: "Portugal", flag: "pt" },
            { name: "RD de Congo", flag: "cd" },
            { name: "Uzbekistán", flag: "uz" },
            { name: "Colombia", flag: "co" }
        ]
    },
    {
        name: "Grupo L",
        teams: [
            { name: "Inglaterra", flag: "gb-eng" },
            { name: "Croacia", flag: "hr" },
            { name: "Ghana", flag: "gh" },
            { name: "Panamá", flag: "pa" }
        ]
