---
import Layout from "../layouts/Layout.astro";
import Content from "../components/layout/Content.astro";
import Grid from "../components/ui/Grid.astro";

import { db } from "../lib/firebase";
import { collection, getDocs, query, orderBy } from "firebase/firestore";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import MemberCard from "../components/ui/team/MemberCard.astro";
import MemberSkeleton from "../components/ui/team/MemberSkeleton.astro";

// Consulta a la colección 'equipo' ordenada por 'posicion'
const q = query(collection(db, "equipo"), orderBy("posicion", "asc"));
const querySnapshot = await getDocs(q);

// Filtrado de miembros activos
const team = querySnapshot.docs
    .map(doc => ({ id: doc.id, ...doc.data() }))
    .filter(member => member.activo !== false);
---

<Layout title="Vacation Planners | Tu Destino México">
    <Content>
        <Header/>

        {/* CONTENEDOR PRINCIPAL INSTITUCIONAL DE VACATION PLANNERS */}
        <section class="py-16 px-4 md:px-12 bg-slate-900 rounded-[2.5rem] mt-8 mb-16 shadow-xl border border-slate-800 relative overflow-hidden">

            {/* ENCABEZADO OPTIMIZADO PARA VENTAS Y SERVICIO */}
            <div class="text-center mb-12 relative z-10 max-w-2xl mx-auto">
                <span class="inline-block py-1 px-4 rounded-full bg-orange-500 text-white text-[10px] font-black uppercase tracking-widest mb-3 shadow-md">
                    Tu Destino MX • Vacation Planners
                </span>
                <h2 class="text-3xl md:text-5xl font-black text-white uppercase tracking-tighter">
                    Diseñamos Tus Mejores Vacaciones
                </h2>
                <p class="text-slate-300 font-medium mt-4 text-sm md:text-base leading-relaxed">
                    Conoce a nuestros <strong class="text-orange-400">Vacation Planners</strong>: un equipo de expertos dedicados a encontrar las mejores tarifas, destinos y experiencias a tu medida. ¡Déjanos planear el viaje de tus sueños!
                </p>
            </div>

            {/* GRILLA DE MIEMBROS DEL EQUIPO */}
            <div class="relative z-10">
                <Grid grid={4}>
                    {team.length > 0 ? (
                        team.map((member) => <MemberCard member={member} />)
                    ) : (
                            <>
                                <MemberSkeleton />
                                <MemberSkeleton />
                                <MemberSkeleton />
                                <MemberSkeleton />
                            </>
                    )}
                </Grid>
            </div>
        </section>
    </Content>
    <Footer />
</Layout>