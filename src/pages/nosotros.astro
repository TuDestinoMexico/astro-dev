---
import Layout from "../layouts/Layout.astro";
import Content from "../components/layout/Content.astro";
import Grid from "../components/ui/Grid.astro";

// 1. Importa tu configuración de Firebase y el Icono
import { db } from "../lib/firebase";
import { collection, getDocs, query, orderBy } from "firebase/firestore";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { Icon } from "astro-icon/components";

// 2. Realiza la consulta a la colección 'equipo' ordenada por el campo 'posicion'
const q = query(collection(db, "equipo"), orderBy("posicion", "asc"));
const querySnapshot = await getDocs(q);

// 3. Mapea los documentos a un array de objetos
const team = querySnapshot.docs.map(doc => ({
    id: doc.id,
    ...doc.data()
}));
---

<Layout title="Nosotros | Tu Destino México">
    <Content>
        <Header/>

        <div
                class="py-16 px-4 md:px-8 bg-cover bg-center bg-no-repeat rounded-3xl mt-8 shadow-inner border border-emerald-900/20"
                style="background-image: url('https://images.unsplash.com/photo-1589496933738-f5c27bc146e3?q=80&w=987&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D');"
        >

            {/* TÍTULO DEL ÁLBUM */}
            <div class="text-center mb-12">
                <span class="inline-block py-1 px-4 rounded-full bg-orange-500 text-white text-[10px] font-black uppercase tracking-widest mb-3 shadow-md">
                    Tu Destino MX
                </span>
                <h2 class="text-4xl md:text-5xl lg:text-6xl font-black text-white uppercase tracking-tighter drop-shadow-[0_4px_4px_rgba(0,0,0,0.8)]">
                    Selección Oficial
                </h2>
                <p class="text-white font-bold mt-3 tracking-wide text-sm md:text-base max-w-xl mx-auto drop-shadow-[0_2px_2px_rgba(0,0,0,0.9)]">
                    Conoce a la alineación titular de expertos que hará de tu próximo viaje una experiencia de campeonato.
                </p>
            </div>

            <Grid grid={4}>
                {team.map((member) => (
                        <article class="group flex flex-col items-center bg-white rounded-xl overflow-hidden shadow-xl border-2 border-white/80 transition-all duration-300 hover:shadow-2xl hover:-translate-y-2 hover:scale-[1.02] p-0 ring-4 ring-black/10">

                            <div class="relative w-full bg-slate-100 overflow-hidden">
                                <img
                                        src={member.foto || "https://placehold.co/400x533?text=Perfil"}
                                        alt={member.nombre}
                                        class="w-full h-full object-cover"
                                />
                                <div class="absolute inset-0 border border-black/10 pointer-events-none"></div>
                                <div class="absolute inset-x-0 bottom-0 h-8 bg-gradient-to-t from-black/30 to-transparent pointer-events-none"></div>
                            </div>

                            <div class="w-full flex flex-col">

                                <div class="bg-green-700 text-white text-center py-2.5 px-2 border-b-2 border-white">
                                    <h3 class="text-sm md:text-base font-black leading-tight uppercase tracking-widest drop-shadow-sm truncate">
                                        {member.nombre}
                                    </h3>
                                </div>

                                {/* ZONA DEL PUESTO CON MARCA DE AGUA DEL BALÓN GIGANTE */}
                                <div class="bg-white text-center py-5 px-3 relative overflow-hidden flex items-center justify-center">

                                    {/* Icono de fondo: Grande, verde transparente y anclado a la izquierda */}
                                    <Icon
                                            name="fa7-solid:futbol"
                                            class="absolute text-green-700/15 w-28 h-28 -left-8 top-1/2 -translate-y-1/2 pointer-events-none transition-transform duration-700 group-hover:rotate-[30deg]"
                                    />

                                    <p class="relative z-10 text-[9px] sm:text-[10px] font-black text-slate-900 uppercase tracking-widest leading-snug text-balance mx-auto drop-shadow-sm">
                                        {member.puesto}
                                    </p>

                                </div>

                            </div>

                        </article>
                ))}
            </Grid>
        </div>
    </Content>
    <Footer />
</Layout>