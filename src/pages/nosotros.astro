---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";
import HeroBanner from "../components/ui/single/HeroBanner.astro";
import Grid from "../components/ui/Grid.astro";
import TeamMember from "../components/ui/team/TeamMember";

// 1. Actualizamos la interfaz para incluir el campo order
interface Member {
    name: string;
    role: string;
    image_url: string;
    order: number; // Campo numérico para la posición
}

const response = await fetch("https://api.tudestinomx.com/api/team");
const rawTeam: Member[] = await response.json();

// 2. Ordenamos el equipo antes de enviarlo al HTML
// (a.order - b.order) ordena de forma ascendente: 1, 2, 3...
const team = rawTeam.sort((a, b) => a.order - b.order);

const defaultImage = "https://tudestinomx-bucket.storage.googleapis.com/wp-content/uploads/2024/12/default-avatar.png";
---

<Layout title="Nosotros | Tu Destino México">
    <Header/>
    <Content>
        <HeroBanner
                title="Nuestro Equipo"
                videoSrc="https://storage.googleapis.com/tudestinomx_bucket/assets/video/Team%20Video%20Noaudio.webm"
                altText="Pagos seguros en Tu Destino México"
        />

        <Grid grid={4}>
            {team.map((member) => (
                    <TeamMember
                            client:only="react"
                            name={member.name}
                            role={member.role}
                            imageSrc={member.image_url || defaultImage}
                    />
            ))}
        </Grid>
    </Content>
    <Footer/>
</Layout>