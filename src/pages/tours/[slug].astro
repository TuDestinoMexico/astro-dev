---
import Layout from '../../layouts/Layout.astro';
import Header from "../../components/layout/Header.astro";
import Footer from "../../components/layout/Footer.astro";
import { Icon } from 'astro-icon/components';
import Gallery from '../../components/ui/hotel/Gallery.astro';
import BookingCalendar from '../../components/ui/BookingCalendar';
import HotelTabs from '../../components/ui/hotel/HotelTabs';

const { slug } = Astro.params;

if (!slug) {
    return Astro.redirect('/404');
}

const token = import.meta.env.VITE_API_TOKEN;

// Fetch al endpoint de tours
const response = await fetch(`https://api.tudestinomx.com/api/tour/slug/${slug}`, {
    headers: {
        'Authorization': `Bearer ${token}`,
        'Accept': 'application/json'
    }
});

if (!response.ok) {
    return Astro.redirect('/404');
}

const data = await response.json();
const tour = data.data || data;

// Procesamiento de amenidades y mapa para Tours
const amenities = tour.amenities_list || [];
const coordinates = tour.google_maps || [];
const address = tour.address || tour.destino || "Ubicación no disponible";

// Procesamiento de imágenes para la galería
const rawImages = tour.images || {};
const allImages = [
    ...(rawImages.principal || []),
    ...(rawImages.secundaria || []),
    ...(rawImages.adicional || [])
];
---

<Layout title={tour.name || "Detalle de Tour"}>
    <Header/>

    <main class="container mx-auto my-8 space-y-8 px-5 xl:px-0">

        <div class="space-y-4">
            <h1 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight">
                {tour.name}
            </h1>

            <div class="flex flex-wrap items-center gap-y-3 gap-x-6 text-sm md:text-base">
                <div class="flex items-center gap-1.5 bg-yellow-50 px-3 py-1 rounded-full border border-yellow-200">
                    <Icon class="text-yellow-500" size={18} name="fa7-solid:star"/>
                    <span class="font-bold text-yellow-700">{tour.reviews ?? '4.8'}</span>
                </div>

                <div class="flex items-start gap-2 flex-1 min-w-0 text-slate-600 font-medium">
                    <Icon class="text-red-500 mt-0.5 flex-shrink-0" size={20} name="fa7-solid:location-dot"/>
                    <p class="truncate md:whitespace-normal">{address}</p>
                </div>
            </div>

            <Gallery images={allImages} hotelName={tour.name} />
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">

            <div class="lg:col-span-2 space-y-6">
                <div class="bg-white border border-slate-100 shadow-sm rounded-2xl overflow-hidden">
                    <HotelTabs
                            client:load
                            description={tour.description}
                            coordinates={coordinates}
                            address={address}
                            amenities={amenities}
                    />
                </div>

                {tour.includes && (
                        <div class="bg-slate-50 border border-slate-100 p-6 rounded-2xl">
                            <h3 class="text-xl font-bold text-slate-800 mb-4">¿Qué incluye esta experiencia?</h3>
                            <div class="prose prose-slate max-w-none text-slate-600" set:html={tour.includes}></div>
                        </div>
                )}
            </div>

            <div class="lg:col-span-1">
                <div class="bg-white border border-slate-200 p-6 rounded-3xl sticky top-24 shadow-xl shadow-slate-200/50">
                    <div class="flex items-center gap-2 mb-6 border-b pb-4 border-slate-100">
                        <Icon name="fa7-solid:calendar-check" size={24} class="text-purple-600"/>
                        <h2 class="text-xl font-black text-slate-800 tracking-tight">Reserva tu aventura</h2>
                    </div>

                    <BookingCalendar
                            client:visible
                            hotelName={tour.name}
                            isSingleDate={true}
                    />

                    <div className="mt-6 pt-6 border-t border-slate-100">
                        <p className="text-[10px] text-center text-slate-400 font-bold uppercase tracking-widest leading-relaxed">
                            Al confirmar, te contactaremos por WhatsApp para finalizar tu reservación y coordinar detalles.
                        </p>
                    </div>
                </div>
            </div>

        </div>
    </main>

    <Footer/>
</Layout>