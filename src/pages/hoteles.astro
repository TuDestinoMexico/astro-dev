---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";
import HeroBanner from "../components/ui/single/HeroBanner.astro";
import Card from "../components/ui/single/Card.astro";

const token = import.meta.env.VITE_API_TOKEN

const response = await fetch('https://api.tudestinomx.com/api/hotel', {
    headers: {
        'Accept': 'application/json',
        'Authorization': `Bearer ${token}`,
    }
});

const data = await response.json();
const rawData = Array.isArray(data) ? data : (data.data || []);
const hoteles = rawData.filter((hotel: any) => Number(hotel.active) === 1);

// Configuramos cuántos mostrar inicialmente
const INITIAL_VISIBLE = 8;
---

<Layout title="Hoteles Exclusivos | Tu Destino México">
    <Header/>

    <Content>
        <HeroBanner
                title="Nuestros Hoteles"
                imageSrc="https://storage.googleapis.com/tudestinomx_bucket/assets/test/Section%20Hoteles.png"
                altText="Fondo sección de hoteles"
        />

        <div class="container mx-auto py-12 px-4">

            <div class="mb-12 text-center">
                <p class="text-xl font-bold text-purple-800 mb-2">Selección Premium</p>
                <h2 class="text-3xl font-extrabold text-gray-800">Encuentra el hospedaje de tus sueños</h2>
            </div>

            {hoteles.length > 0 ? (
                    <div class="flex flex-col items-center">
                        <div id="hotel-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 w-full">
                            {hoteles.map((hotel: any, index: number) => (
                                    <div class={`hotel-card ${index >= INITIAL_VISIBLE ? 'hidden' : ''}`}>
                                        <Card
                                                title={hotel.name || hotel.title}
                                                slug={hotel.slug}
                                                type="hoteles"
                                                destino={hotel.destino}
                                                photo={hotel.images || hotel.imagenes}
                                        />
                                    </div>
                            ))}
                        </div>

                        {hoteles.length > INITIAL_VISIBLE && (
                                <button
                                        id="load-more-btn"
                                        class="mt-12 px-8 py-3 bg-purple-800 text-white font-bold rounded-full hover:bg-purple-900 transition-colors shadow-lg"
                                >
                                    Ver más hoteles
                                </button>
                        )}
                    </div>
            ) : (
                    <div class="text-center py-20">
                        <p class="text-gray-500 italic">No se encontraron hoteles disponibles en este momento.</p>
                    </div>
            )}
        </div>
    </Content>

    <Footer/>
</Layout>

<script>
    const btn = document.getElementById('load-more-btn');
    const cards = document.querySelectorAll('.hotel-card.hidden');
    let currentVisible = 8;
    const increment = 8;

    btn?.addEventListener('click', () => {
        const hiddenCards = document.querySelectorAll('.hotel-card.hidden');

        // Mostramos el siguiente bloque de 8
        for (let i = 0; i < increment; i++) {
            if (hiddenCards[i]) {
                hiddenCards[i].classList.remove('hidden');
                // Añadimos una pequeña animación de entrada opcional
                hiddenCards[i].classList.add('animate-fade-in');
            }
        }

        // Si ya no hay más cartas ocultas, quitamos el botón
        if (document.querySelectorAll('.hotel-card.hidden').length === 0) {
            btn.style.display = 'none';
        }
    });
</script>

<style>
    /* Animación suave para cuando aparecen los nuevos hoteles */
    .animate-fade-in {
        animation: fadeIn 0.5s ease forwards;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>