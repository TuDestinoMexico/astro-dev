---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";
import HeroBanner from "../components/ui/single/HeroBanner.astro";

const alianzasExclusivas = [
    {
        empresa: "Sams Club Afiliados",
        descripcion: "Con tu Membresía física o digital PLUS o Benefits obtén un 15% descuento ó paquetes a costo preferencial de $13,990 (5 días y 4 noches)",
        beneficios: []
    },
    {
        empresa: "Cupón Click",
        descripcion: "Con tu Membresía física o digital PLUS o Benefits obtén un 15% descuento ó paquetes a costo preferencial de $13,990 (5 días y 4 noches)",
        beneficios: []
    },
    {
        empresa: "Nissan",
        descripcion: "",
        beneficios: [
            "Paquetes en $13,990",
            "35% de descuento en hoteles",
            "25% en tours y traslados"
        ]
    }
];
---

<Layout title="Convenios Corporativos | Tu Destino México">
    <Header/>

    <Content>
        <HeroBanner
                title="Convenios y Alianzas"
                imageSrc="https://images.unsplash.com/photo-1556761175-b413da4baf72?q=80&w=2074&auto=format&fit=crop"
                altText="Reunión corporativa para convenios"
        />

        <div class="max-w-5xl mx-auto px-6 py-12">

            <section class="text-center mb-16">
                <p class="text-xl font-bold text-purple-800 mb-4 uppercase tracking-wider">
                    Beneficios Exclusivos para tu Empresa
                </p>
                <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mb-6">
                    Llevamos a tu equipo a los mejores destinos
                </h2>
                <p class="text-gray-600 text-lg leading-relaxed max-w-3xl mx-auto">
                    En <strong>Tu Destino México</strong>, creamos alianzas estratégicas con empresas e instituciones para ofrecer tarifas preferenciales, planes de financiamiento y experiencias únicas a sus colaboradores.
                </p>
            </section>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-20">
                <div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-md transition-shadow">
                    <div class="bg-purple-100 w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-purple-800" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                    </div>
                    <h3 class="font-bold text-xl mb-2">Tarifas Especiales</h3>
                    <p class="text-gray-600 text-sm">Precios preferenciales por debajo del mercado para todos los empleados.</p>
                </div>

                <div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-md transition-shadow">
                    <div class="bg-orange-100 w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>
                    </div>
                    <h3 class="font-bold text-xl mb-2">Pagos Flexibles</h3>
                    <p class="text-gray-600 text-sm">Opciones de descuento por nómina o facilidades de pago diferido.</p>
                </div>

                <div class="bg-gray-50 p-8 rounded-2xl border border-gray-100 text-center hover:shadow-md transition-shadow">
                    <div class="bg-blue-100 w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-4">
                        <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path></svg>
                    </div>
                    <h3 class="font-bold text-xl mb-2">Atención VIP</h3>
                    <p class="text-gray-600 text-sm">Un asesor dedicado para gestionar las vacaciones de tus colaboradores.</p>
                </div>
            </div>

            <div class="bg-white border border-gray-200 rounded-3xl p-8 md:p-12 shadow-sm mb-16">
                <h2 class="text-2xl font-bold text-gray-900 mb-6">¿Cómo funciona nuestro programa de convenios?</h2>
                <div class="space-y-6 text-gray-700">
                    <p>
                        Nuestro programa de convenios está diseñado para empresas que buscan incentivar a su personal. No tiene costo de afiliación para la empresa y ofrece beneficios inmediatos.
                    </p>
                    <ul class="list-disc pl-6 space-y-3">
                        <li><strong>Sin costo administrativo:</strong> Nosotros nos encargamos de toda la logística de viaje.</li>
                        <li><strong>Personalización:</strong> Creamos paquetes a la medida según el perfil de tu empresa.</li>
                        <li><strong>Alcance Nacional:</strong> Descuentos válidos en hoteles, tours y transportación en todo México.</li>
                    </ul>
                </div>
            </div>

            <section class="my-16 px-4">
                <div class="max-w-7xl mx-auto">
                    <div class="mb-10">
                        <h2 class="text-3xl font-extrabold text-purple-800">Convenios Vigentes</h2>
                        <p class="text-slate-500 mt-2">Aprovecha los beneficios exclusivos que tenemos para ti a través de nuestras alianzas.</p>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {alianzasExclusivas.map((aliado) => (
                                <div class="flex flex-col justify-between p-7 bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
                                    <div>
                        <span class="inline-block px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-[10px] font-bold uppercase tracking-wider mb-4">
                            {aliado.tipo}
                        </span>

                                        <h3 class="text-2xl font-bold text-slate-800 mb-3">
                                            {aliado.empresa}
                                        </h3>

                                        {aliado.descripcion && (
                                                <p class="text-slate-600 text-sm leading-relaxed mb-4">
                                                    {aliado.descripcion}
                                                </p>
                                        )}

                                        {aliado.beneficios && aliado.beneficios.length > 0 && (
                                                <ul class="space-y-2 mb-6">
                                                    {aliado.beneficios.map((beneficio) => (
                                                            <li class="flex items-start text-slate-600 text-sm">
                                                                <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                                </svg>
                                                                {beneficio}
                                                            </li>
                                                    ))}
                                                </ul>
                                        )}
                                    </div>

                                    <div class="mt-6 pt-6 border-t border-gray-100">
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Cupón disponible</span>
                                            <a
                                                    href="https://wa.me/529989806611"
                                                    target="_blank"
                                                    class="inline-flex items-center justify-center px-6 py-2.5 bg-slate-900 text-white text-sm font-bold rounded-xl hover:bg-purple-800 transition-colors shadow-sm"
                                            >
                                                Ver beneficio
                                            </a>
                                        </div>
                                    </div>
                                </div>
                        ))}
                    </div>
                </div>
            </section>

            <section class="bg-purple-900 rounded-3xl p-10 text-center text-white">
                <h2 class="text-3xl font-bold mb-4">¿Representas a una empresa?</h2>
                <p class="mb-8 opacity-90 max-w-xl mx-auto">Déjanos tus datos y un ejecutivo de alianzas corporativas se pondrá en contacto contigo para presentarte nuestra propuesta comercial.</p>

                <div class="flex flex-col sm:flex-row gap-4 justify-center">
                    <a
                            href="https://wa.me/529989806611?text=Hola,%20busco%20información%20sobre%20convenios%20empresariales"
                            target="_blank"
                            class="bg-green-500 hover:bg-green-600 text-white px-10 py-4 rounded-xl font-bold transition-all shadow-lg"
                    >
                        Solicitar información vía WhatsApp
                    </a>
                    <a
                            href="mailto:gerencia@tudestinomx.com"
                            class="bg-white/10 hover:bg-white/20 border border-white/30 text-white px-10 py-4 rounded-xl font-bold transition-all"
                    >
                        Enviar correo formal
                    </a>
                </div>
                <p class="mt-6 text-sm opacity-60 italic">Únete a las más de 50 empresas que ya viajan con nosotros.</p>
            </section>

        </div>
    </Content>

    <Footer/>
</Layout>