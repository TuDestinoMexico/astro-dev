---
import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import Content from "../components/layout/Content.astro";

const alianzasExclusivas = [
    {
        empresa: "Sams Club Afiliados",
        tipo: "Afiliación PLUS / Benefits",
        descripcion: "Con tu Membresía física o digital PLUS o Benefits obtén:",
        beneficios: [
            "15% de descuento",
            "Paquetes a costo preferencia por $18,990"
        ],
        url: "https://www.samsbenefits.com/resultados/detalles/Tu-Destino-M%C3%A9xico/P7562"
    },
    {
        empresa: "Nissan",
        tipo: "Colaborador Corporativo",
        descripcion: "Si eres un colaborador de Grupo Nissan, escapate a unas vacaciones en la playa.",
        url: "https://conveniosnissan.com/c/Tu-Destino-Mexico_12668",
        beneficios: [
            "Paquetes en $13,990",
            "35% de descuento en hoteles",
            "25% en tours y traslados"
        ]
    }
];
---

<Layout title="Convenios Corporativos | Tu Destino México">
    <Header/>

    <Content>
        {/* Contenedor optimizado para centrar y dar espaciado exclusivo a las tarjetas */}
        <div class="max-w-5xl mx-auto px-6 py-12">

            <section class="my-8 px-4">
                <div class="max-w-7xl mx-auto">

                    {/* Encabezado directo de la sección de convenios */}
                    <div class="mb-10 text-center md:text-left">
                        <h2 class="text-3xl font-extrabold text-purple-800">Convenios Vigentes</h2>
                        <p class="text-slate-500 mt-2">Aprovecha los beneficios exclusivos que tenemos para ti a través de nuestras alianzas.</p>
                    </div>

                    {/* Renderizado dinámico de la lista de alianzas */}
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                        {alianzasExclusivas.map((aliado) => (
                                <div class="flex flex-col justify-between p-7 bg-white border border-gray-200 rounded-2xl shadow-sm hover:shadow-md transition-shadow">
                                    <div>
                                        <span class="inline-block px-3 py-1 rounded-full bg-orange-100 text-orange-700 text-[10px] font-bold uppercase tracking-wider mb-4">
                                            {aliado.tipo}
                                        </span>

                                        <h3 class="text-2xl font-bold text-slate-800 mb-3">
                                            {aliado.empresa}
                                        </h3>

                                        {aliado.descripcion && (
                                                <p class="text-slate-600 text-sm leading-relaxed mb-4">
                                                    {aliado.descripcion}
                                                </p>
                                        )}

                                        {aliado.beneficios && aliado.beneficios.length > 0 && (
                                                <ul class="space-y-2 mb-6">
                                                    {aliado.beneficios.map((beneficio) => (
                                                            <li class="flex items-start text-slate-600 text-sm">
                                                                <svg class="w-5 h-5 text-green-500 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                                                                </svg>
                                                                {beneficio}
                                                            </li>
                                                    ))}
                                                </ul>
                                        )}
                                    </div>

                                    <div class="mt-6 pt-6 border-t border-gray-100">
                                        <div class="flex items-center justify-between">
                                            <span class="text-xs font-bold text-slate-400 uppercase tracking-widest">Cupón disponible</span>
                                            <a
                                                    href={aliado.url}
                                                    target="_blank"
                                                    class="inline-flex items-center justify-center px-6 py-2.5 bg-slate-900 text-white text-sm font-bold rounded-xl hover:bg-purple-800 transition-colors shadow-sm"
                                            >
                                                Ver beneficio
                                            </a>
                                        </div>
                                    </div>
                                </div>
                        ))}
                    </div>
                </div>
            </section>

        </div>
    </Content>

    <Footer/>
</Layout>