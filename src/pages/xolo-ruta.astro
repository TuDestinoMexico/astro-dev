---

import Layout from "../layouts/Layout.astro";
import Header from "../components/layout/Header.astro";
import Content from "../components/layout/Content.astro";
import Footer from "../components/layout/Footer.astro";
import Timeline from "../components/ui/timeline/Timeline";
import HeroBanner from "../components/ui/single/HeroBanner.astro";
---
<Layout title="Xolo Ruta | Tu Destino Mexico">
    <Header/>
        <Content>
            <HeroBanner
                    title="Nuestra Xolo Ruta"
                    videoSrc="https://storage.googleapis.com/tudestinomx_bucket/assets/video/Team%20Video%20Noaudio.webm"
                    altText="Pagos seguros en Tu Destino México"
            />
            <Timeline client:only="react" />
        </Content>
    <Footer />

</Layout>